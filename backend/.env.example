# ============================================================
# WhatsApp PSX Bot — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_NAME="WhatsApp PSX Bot"
DEBUG=false
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_psx

# ------------------------------------------------------------
# WhatsApp Business Cloud API (Meta)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# ------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=your-permanent-system-user-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# Optional: enable HMAC signature verification on incoming webhooks
WEBHOOK_SECRET=
WEBHOOK_SIGNATURE_VERIFICATION=false

# ------------------------------------------------------------
# Redis
# Use separate DBs so cache, broker, and results don't collide.
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------
# PSX market data
# ------------------------------------------------------------
PSX_DPS_BASE_URL=https://dps.psx.com.pk
PSX_CACHE_TTL_LIVE=60       # seconds — during market hours (09:15–15:30 PKT)
PSX_CACHE_TTL_CLOSED=900    # seconds — after hours / weekends

# ------------------------------------------------------------
# Alert engine
# ------------------------------------------------------------
ALERT_COOLDOWN_MINUTES=60   # min gap between repeated non-one-shot alerts
ALERT_CHECK_INTERVAL=60     # seconds between Celery alert-checker runs
WA_SEND_DELAY_MS=100        # ms delay between bulk WhatsApp sends

# ------------------------------------------------------------
# OpenAI (used by RAG pipeline — not PSX features)
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4-turbo

# ------------------------------------------------------------
# Whisper (speech-to-text)
# ------------------------------------------------------------
WHISPER_API_KEY=sk-...

# ------------------------------------------------------------
# Pinecone (vector store for RAG pipeline)
# ------------------------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key

# ------------------------------------------------------------
# Qdrant (alternative vector store)
# ------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
ENCRYPTION_KEY=change-me-use-fernet-generate-key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------------------------
# CORS (comma-separated origins, or * for dev)
# ------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
